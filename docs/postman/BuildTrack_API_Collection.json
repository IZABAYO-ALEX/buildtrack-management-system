              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/projects?status=active",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects"],
              "query": [
                {
                  "key": "status",
                  "value": "active"
                }
              ]
