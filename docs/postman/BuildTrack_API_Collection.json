              "mode": "raw",
              "raw": "{\n  \"name\": \"Kampala Heights Apartment\",\n  \"description\": \"12-story residential apartment building in Kampala\",\n  \"budget\": 500000,\n  \"location\": \"Kampala, Uganda\",\n  \"startDate\": \"2024-01-01\",\n  \"endDate\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects"]
            }
          },
          "response": []
