      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"contractor@buildtrack.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"John Contractor\",\n  \"role\": \"contractor\",\n  \"phone\": \"+256701234567\",\n  \"companyName\": \"BuildTrack Construction Ltd\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": []
        },
        {
